# Copiá este archivo a ".env" (sin el .txt) y rellená los valores reales.
# .env NUNCA se commitea (está en .gitignore).

# === API de MiniMax ===========================================================
# Tu clave privada de la API. No la compartas con nadie.
MINIMAX_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint base de la API.
# Ejemplo si es OpenAI-compatible: https://api.minimax.chat/v1
# Confirmá con la doc oficial de MiniMax cuál es la URL exacta.
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Modelo a invocar. Confirmá con la doc cuál es el identificador exacto
# del modelo que querés usar (ej: MiniMax-M3, MiniMax-M2, etc.).
MINIMAX_MODEL=MiniMax-M3
